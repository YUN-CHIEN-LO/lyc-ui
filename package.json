{
  "name": "@yun-chien-lo/lyc-ui",
  "type": "module",
  "version": "0.0.43",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "sass": "sass --no-source-map --style=compressed src/styles:dist/css && cp -R ./src/styles ./dist/scss",
    "build": "vue-tsc --noEmit && vite build",
    "clean": "rm -rf ./dist",
    "prebuild": "npm run clean",
    "postbuild": "npm run sass"
  },
  "dependencies": {
    "@vueuse/core": "^9.13.0",
    "lodash": "^4.17.21",
    "prismjs": "^1.29.0",
    "vue": "^3.2.47",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.15.9",
    "@types/prismjs": "^1.26.0",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "@vue/babel-plugin-jsx": "^1.1.1",
    "glob": "^9.3.1",
    "sass": "^1.59.3",
    "terser": "^5.16.6",
    "typescript": "^5.0.2",
    "vite": "^4.2.0",
    "vite-plugin-prismjs": "^0.0.8",
    "vue-tsc": "^1.2.0"
  },
  "description": "",
  "main": "./dist/js/lyc-ui.js",
  "module": "./dist/js/lyc-ui.js",
  "exports": {
    ".": {
      "import": "./dist/js/lyc-ui.js",
      "require": "./dist/js/lyc-ui.js"
    },
    "./dist/css/lyc-ui.css": {
      "import": "./dist/css/lyc-ui.css",
      "require": "./dist/css/lyc-ui.css"
    },
    "./dist/scss/lyc-ui.scss": {
      "import": "./dist/scss/lyc-ui.scss",
      "require": "./dist/scss/lyc-ui.scss"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YUN-CHIEN-LO/lyc-ui.git"
  },
  "author": "yun-chien-lo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YUN-CHIEN-LO/lyc-ui/issues"
  },
  "homepage": "https://github.com/YUN-CHIEN-LO/lyc-ui#readme"
}
